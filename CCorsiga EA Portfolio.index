<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Constancio Corsiga III — Executive & Admin Support Specialist</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #0B1F3A;
    --navy-mid: #132A4E;
    --navy-light: #1C3A65;
    --gold: #C8A84B;
    --gold-light: #E2C97E;
    --gold-pale: #F5EDCF;
    --cream: #FAF8F3;
    --white: #FFFFFF;
    --text-dark: #0B1F3A;
    --text-mid: #334E6E;
    --text-muted: #6B849E;
    --border: #D8E2EE;
    --section-gap: 80px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--cream);
    color: var(--text-dark);
    line-height: 1.6;
    font-size: 16px;
  }

  /* ── NAVIGATION ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(11, 31, 58, 0.97);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(200, 168, 75, 0.25);
    padding: 0 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    color: #FFFFFF;  /*changed color for contrast */
    /* color: var(--gold); */
    letter-spacing: 0.5px;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--gold); }

  /* ── HERO ── */
  .hero {
    background: var(--navy);
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -10%;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    border: 1px solid rgba(200, 168, 75, 0.08);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    right: 5%;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    border: 1px solid rgba(200, 168, 75, 0.05);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 56px;
    align-items: center;
  }

  /* ── HERO PHOTO PLACEHOLDER ── */
  .hero-photo-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
   /* width: 100%;
    width: 100%; */
    gap: 14px; 
    flex-shrink: 0; 
  }

  .hero-photo-placeholder {
    width: 320px;
    height: 460px;
    border-radius: 10px;
    border: 2px dashed rgba(200, 168, 75, 0.5);
    background: rgba(19, 42, 78, 0.6);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    position: relative;
    overflow: hidden;
  }

  .hero-photo-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 8px,
      rgba(200, 168, 75, 0.03) 8px,
      rgba(200, 168, 75, 0.03) 16px
    );
  }

  .hero-photo-icon {
    font-size: 40px;
    opacity: 0.5;
    position: relative;
    z-index: 1;
  }

  .hero-photo-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(200, 168, 75, 0.6);
    text-align: center;
    line-height: 1.5;
    position: relative;
    z-index: 1;
    padding: 0 16px;
  }

  .hero-photo-note {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    text-align: center;
    letter-spacing: 0.3px;
  }

  .hero-eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 1px;
    background: var(--gold);
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(38px, 5vw, 58px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 24px;
    letter-spacing: -0.5px;
  }

  .hero h1 span {
    color: var(--gold);
    display: block;
  }

  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 460px;
  }

  .hero-cta-group {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--gold);
    color: var(--navy);
    font-weight: 600;
    font-size: 14px;
    padding: 14px 28px;
    border-radius: 4px;
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary:hover { background: var(--gold-light); transform: translateY(-1px); }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(200, 168, 75, 0.4);
    color: var(--gold-light);
    font-weight: 500;
    font-size: 14px;
    padding: 14px 28px;
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

  .hero-stats-col {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  /* Hero right — stat panel */
  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: rgba(200, 168, 75, 0.15);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(200, 168, 75, 0.2);
  }

  .stat-cell {
    background: rgba(19, 42, 78, 0.85);
    padding: 32px 28px;
    text-align: center;
  }

  .stat-cell:first-child { border-radius: 6px 0 0 0; }
  .stat-cell:nth-child(2) { border-radius: 0 6px 0 0; }
  .stat-cell:nth-child(3) { border-radius: 0 0 0 6px; }
  .stat-cell:last-child { border-radius: 0 0 6px 0; }

  .stat-number {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 8px;
    display: block;
  }

  .stat-label {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* ── SECTION COMMON ── */
  .section {
    padding: var(--section-gap) 48px;
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-eyebrow::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
    max-width: 60px;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 38px);
    font-weight: 700;
    color: var(--navy);
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .section-intro {
    font-size: 16px;
    color: var(--text-mid);
    max-width: 600px;
    line-height: 1.7;
    margin-bottom: 56px;
  }

  /* ── VALUE PROPOSITIONS ── */
  .value-section {
    background: var(--white);
  }

  .value-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .value-card {
    background: var(--white);
    padding: 40px 36px;
    position: relative;
  }

  .value-card::before {
    content: '';
    display: block;
    width: 36px;
    height: 3px;
    background: var(--gold);
    margin-bottom: 28px;
    border-radius: 2px;
  }

  .value-icon {
    font-size: 28px;
    margin-bottom: 16px;
    display: block;
  }

  .value-card h3 {
    font-size: 17px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 12px;
    line-height: 1.3;
  }

  .value-card p {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.7;
  }

  /* ── SKILLS ── */
  .skills-section {
    background: var(--cream);
  }

  .skills-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  .skill-group {
    margin-bottom: 36px;
  }

  .skill-group-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-tag {
    font-size: 13px;
    font-weight: 500;
    color: var(--navy-mid);
    background: var(--white);
    border: 1px solid var(--border);
    padding: 6px 14px;
    border-radius: 3px;
    letter-spacing: 0.2px;
    transition: border-color 0.15s, color 0.15s;
  }

  .skill-tag:hover {
    border-color: var(--gold);
    color: var(--text-dark);
  }

  .skill-tag.highlight {
    background: var(--gold-pale);
    border-color: rgba(200, 168, 75, 0.4);
    color: #7A5C1E;
  }

  /* tools side */
  .tools-panel {
    background: var(--navy);
    border-radius: 10px;
    padding: 40px 36px;
    position: sticky;
    top: 88px;
  }

  .tools-panel-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    color: var(--white);
    margin-bottom: 8px;
  }

  .tools-panel-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 28px;
  }

  .tool-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .tool-item:last-child { border-bottom: none; }

  .tool-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold);
    flex-shrink: 0;
  }

  .tool-dot.secondary {
    background: rgba(200,168,75,0.35);
  }

  .tool-name {
    font-size: 14px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
  }

  .tool-cat {
    font-size: 11px;
    color: rgba(255,255,255,0.38);
    margin-left: auto;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  /* ── EXPERIENCE ── */
  .experience-section {
    background: var(--white);
  }

  .timeline {
    position: relative;
    padding-left: 32px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: linear-gradient(to bottom, var(--gold), var(--border) 80%, transparent);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 56px;
  }

  .timeline-item:last-child { margin-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: -36px;
    top: 6px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gold);
    border: 2px solid var(--white);
    box-shadow: 0 0 0 2px var(--gold);
  }

  .timeline-dot.secondary {
    background: var(--border);
    box-shadow: 0 0 0 2px var(--border);
  }

  .timeline-meta {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }

  .timeline-period {
    font-size: 12px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }

  .timeline-company {
    font-size: 13px;
    color: var(--text-muted);
  }

  .timeline-role {
    font-size: 20px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 6px;
    line-height: 1.3;
  }

  .timeline-location {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .timeline-location::before {
    content: '◆';
    font-size: 7px;
    color: var(--gold);
  }

  .achievement-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .achievement-list li {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.65;
    padding-left: 18px;
    position: relative;
  }

  .achievement-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 12px;
    top: 2px;
  }

  .achievement-list li strong {
    color: var(--navy);
    font-weight: 600;
  }

  /* ── METRICS ── */
  .metrics-section {
    background: var(--navy);
    padding: var(--section-gap) 48px;
  }

  .metrics-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .metrics-header {
    text-align: center;
    margin-bottom: 56px;
  }

  .metrics-header .section-eyebrow {
    justify-content: center;
  }

  .metrics-header .section-eyebrow::after { display: none; }

  .metrics-header .section-title {
    color: var(--white);
  }

  .metrics-header .section-intro {
    color: rgba(255,255,255,0.55);
    margin: 0 auto;
  }

  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    background: rgba(200, 168, 75, 0.1);
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(200, 168, 75, 0.15);
  }

  .metric-cell {
    background: rgba(19, 42, 78, 0.9);
    padding: 40px 32px;
    text-align: center;
  }

  .metric-number {
    font-family: 'Playfair Display', serif;
    font-size: 48px;
    font-weight: 700;
    color: var(--gold);
    display: block;
    line-height: 1;
    margin-bottom: 8px;
  }

  .metric-label {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    line-height: 1.4;
  }

  /* ── TRUST SIGNALS ── */
  .trust-section {
    background: var(--cream);
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .trust-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 32px 28px;
  }

  .trust-card-type {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .trust-card h3 {
    font-size: 16px;
    font-weight: 600;
    color: var(--navy);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .trust-card p {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .cert-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 8px;
  }

  .cert-list li {
    font-size: 13px;
    color: var(--text-mid);
    padding-left: 16px;
    position: relative;
    line-height: 1.5;
  }

  .cert-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 12px;
    font-weight: 700;
  }

  .cert-year {
    font-size: 11px;
    color: var(--text-muted);
    float: right;
  }

  /* ── AVAILABILITY BANNER ── */
  .availability-section {
    background: var(--white);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 40px 48px;
  }

  .avail-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .avail-left {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .avail-indicator {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .pulse {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #22C55E;
    position: relative;
  }

  .pulse::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 2px solid #22C55E;
    opacity: 0.4;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.4; }
    50% { transform: scale(1.4); opacity: 0; }
  }

  .avail-text strong {
    font-size: 16px;
    font-weight: 600;
    color: var(--navy);
    display: block;
  }

  .avail-text span {
    font-size: 13px;
    color: var(--text-muted);
  }

  .avail-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .avail-tag {
    font-size: 12px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 20px;
    border: 1px solid var(--border);
    color: var(--text-mid);
  }

  /* ── CONTACT ── */
  .contact-section {
    background: var(--navy);
    padding: var(--section-gap) 48px;
  }

  .contact-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .contact-left .section-title { color: var(--white); }
  .contact-left .section-intro { color: rgba(255,255,255,0.55); }

  .contact-detail {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .contact-detail:last-child { border-bottom: none; }

  .contact-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(200, 168, 75, 0.12);
    border: 1px solid rgba(200, 168, 75, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    flex-shrink: 0;
  }

  .contact-info strong {
    display: block;
    font-size: 15px;
    font-weight: 500;
    color: var(--white);
  }

  .contact-info span {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }

  /* ── FOOTER ── */
  footer {
    background: rgba(7, 16, 30, 0.95);
    padding: 24px 48px;
    text-align: center;
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  footer span { color: var(--gold); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 0 24px; }
    .nav-links { gap: 20px; }
    .hero { padding: 100px 24px 60px; }
    .hero-inner { grid-template-columns: 1fr; gap: 40px; }
    .hero-photo-placeholder { width: 160px; height: 190px; }
    .hero-photo-wrap { order: -1; }
    .hero-stats-col { justify-content: center; }
    .section { padding: 60px 24px; }
    .value-grid { grid-template-columns: 1fr; }
    .skills-layout { grid-template-columns: 1fr; }
    .tools-panel { position: static; }
    .metrics-grid { grid-template-columns: 1fr 1fr; }
    .trust-grid { grid-template-columns: 1fr; }
    .avail-inner { flex-direction: column; align-items: flex-start; }
    .contact-inner { grid-template-columns: 1fr; gap: 48px; }
    .contact-section { padding: 60px 24px; }
    .metrics-section { padding: 60px 24px; }
    .availability-section { padding: 32px 24px; }
    footer { padding: 24px; }
  }

  @media (max-width: 600px) {
    .nav-links { display: none; }
    .hero-stats { grid-template-columns: 1fr 1fr; }
    .metrics-grid { grid-template-columns: 1fr 1fr; }
  }

  /* Print */
  @media print {
