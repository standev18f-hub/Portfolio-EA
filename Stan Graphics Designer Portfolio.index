<script>
  const reveals = document.querySelectorAll('.reveal');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.15 });
  reveals.forEach(el => io.observe(el));
</script>


<script>

  // ============================================================
  //  EMAIL LINK HANDLER
  // ============================================================

  const EMAIL_CONFIG = {
    to: 'stan.dev18f+02Gpx@gmail.com',
    subject: 'Interview for Executive Support Specialist',
    body: 'Hi, Are you open for an interview on            at         .',
  };

  // ── Build mailto URL ─────────────────────────────────────────
  function buildMailtoURL(config) {
    const subject = encodeURIComponent(config.subject);
    const body = encodeURIComponent(config.body);
    return `mailto:${config.to}?subject=${subject}&body=${body}`;
  }

  // ── Attach to all email links ────────────────────────────────
  function initEmailLinks() {
    // Targets <a href="mailto:..."> links
    const mailtoLinks = document.querySelectorAll('a[href^="mailto:"]');

    // Targets any element with class .email-link
    const classLinks = document.querySelectorAll('.email-link');

    const allLinks = [...new Set([...mailtoLinks, ...classLinks])];

    if (allLinks.length === 0) {
      console.warn('No email links found on this page.');
      return;
    }

    allLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();

        // Use custom config or fall back to the link's own href
        const mailtoURL = link.href.startsWith('mailto:')
          ? link.href
          : buildMailtoURL(EMAIL_CONFIG);

        console.log('Opening email client:', mailtoURL);
        window.location.href = mailtoURL;
      });
    });

    console.log(`Email handler attached to ${allLinks.length} link(s).`);
  }

  // ── Run after DOM is ready ───────────────────────────────────
  document.addEventListener('DOMContentLoaded', initEmailLinks);


</script>












